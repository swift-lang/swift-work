#!/bin/bash
set -eu

# Presume success:
CODE=0

crash()
{
  echo "report:" ${*}
  exit 1
}

grep-check()
# Handle grep not-found cases
# Sets global CODE=1 but does not crash script
{
  if grep "${@}"
  then
    : OK
  else
    local PATTERN="$1"
    shift
    echo "pattern '$PATTERN' not found in ${*}"
    # Global CODE
    CODE=1
  fi
}

grep-maybe()
# Handle grep not-found cases
# Ignores not-found case
{
  if grep "${@}"
  then
    : OK
  else
    : OK
  fi
}

if (( ${#} != 1 ))
then
  crash "provide DIR"
fi
DIR=$1

if ! [[ -d $DIR ]]
then
  crash "no directory: $DIR"
fi
if ! [[ -f $DIR/jobid.txt ]]
then
  crash "no jobid file: $DIR"
fi

echo -n "JOB:                "
# Cut out Aurora junk from ID:
head -c 7                $DIR/jobid.txt
echo
# Want NODES at top for readability
grep "NODES"             $DIR/turbine.log
grep "PROCS\|PPN"        $DIR/turbine.log
grep "TURBINE_WORKERS"   $DIR/turbine.log
grep "ADLB_SERVERS"      $DIR/turbine.log
grep-maybe "Swift:"      $DIR/output.txt
grep-maybe "N:\|M:"      $DIR/output.txt
if grep "died\|exceeded" $DIR/output.txt
then
  CODE=1
fi
grep-maybe "TASKS:"    $DIR/output.txt
if grep "EXIT CODE:"   $DIR/output.txt
then
  grep-check "COMPLETED:"               $DIR/output.txt
  grep-check "ADLB Total Elapsed Time:" $DIR/output.txt
else
  echo "job not complete: $DIR"
  CODE=1
fi

exit $CODE
